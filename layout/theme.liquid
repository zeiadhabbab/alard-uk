<script>
document.addEventListener('DOMContentLoaded', function () {
  const hasDatesInUrl =
    window.location.pathname.includes('dates') || window.location.pathname.includes('build') ||
    window.location.search.includes('dates=');

  if (
    hasDatesInUrl &&
    sessionStorage.getItem('reloaded_after_cart') === '1'
  ) {
       // Preventing rapid loops: Check if we just reloaded recently (e.g., within 5 seconds)
      const lastReload = sessionStorage.getItem('last_auto_reload');
      const now = Date.now();
      if (lastReload && now - parseInt(lastReload) < 500) {
           // Too soon, clear the flag to stop the loop
           sessionStorage.setItem('reloaded_after_cart', '0');
           return;
      }

    setTimeout(function () {
      const url = new URL(window.location.href);

      // cache bust
      url.searchParams.set(
        '_r',
        Math.random().toString(36).substring(2, 8)
      );
      
      // scroll to section
      url.hash = '#build-your-box';

      // reset flag to avoid loop
      sessionStorage.setItem('reloaded_after_cart', '0');
      sessionStorage.setItem('last_auto_reload', Date.now().toString());

      window.location.replace(url.toString());
    }, 0);
  }
});
</script>


