{%- liquid
  assign section_id = 'about-alard-' | append: section.id
-%}

<style>
  #{{ section_id }} {
    --aa-bg: {{ section.settings.background_color }};
    --aa-card: {{ section.settings.card_color }};
    --aa-text: {{ section.settings.text_color }};
    --aa-label: {{ section.settings.accent_color }};
    --aa-heading: {{ section.settings.heading_color }};
    --aa-border: rgba(105, 92, 67, 0.18);
    padding: {{ section.settings.padding_top }}px 1.5rem {{ section.settings.padding_bottom }}px;
    background-color: var(--aa-bg);
    font-family: var(--font-body-family);
  }

  #{{ section_id }} * { box-sizing: border-box; }

  #{{ section_id }} .aa-wrap {
    max-width: 1240px;
    margin: 0 auto;
    background: var(--aa-card);
    border: 1px solid var(--aa-border);
    border-radius: 20px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 560px;
  }

  /* Image */
  #{{ section_id }} .aa-image {
    position: relative;
    overflow: hidden;
  }

  #{{ section_id }} .aa-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #{{ section_id }} .aa-image-placeholder {
    width: 100%;
    height: 100%;
    min-height: 480px;
    background: #ddd3bb;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #9e8f78;
    font-size: 0.9rem;
  }

  /* Content */
  #{{ section_id }} .aa-content {
    padding: 3.5rem 3rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.25rem;
    color: var(--aa-text);
  }

  /* Label */
  #{{ section_id }} .aa-label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--aa-label);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  #{{ section_id }} .aa-label::before,
  #{{ section_id }} .aa-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--aa-label);
    opacity: 0.45;
    max-width: 2rem;
  }

  #{{ section_id }} .aa-label::before { max-width: 0.5rem; }

  /* Heading */
  #{{ section_id }} .aa-heading {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--aa-heading);
    margin: 0;
  }

  /* Decorative divider */
  #{{ section_id }} .aa-divider {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--aa-label);
    opacity: 0.55;
  }

  #{{ section_id }} .aa-divider::before,
  #{{ section_id }} .aa-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: currentColor;
    max-width: 3rem;
  }

  #{{ section_id }} .aa-divider svg {
    width: 20px;
    height: 14px;
    flex-shrink: 0;
  }

  /* Body */
  #{{ section_id }} .aa-body {
    font-size: 0.97rem;
    line-height: 1.75;
    color: var(--aa-text);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  #{{ section_id }} .aa-body p { margin: 0; }

  /* Icon grid */
  #{{ section_id }} .aa-icons {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--aa-border);
    margin-top: 0.5rem;
    padding-top: 1.25rem;
  }

  #{{ section_id }} .aa-icon-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
    padding: 0 0.5rem;
    border-right: 1px solid var(--aa-border);
    text-align: center;
  }

  #{{ section_id }} .aa-icon-item:last-child { border-right: none; }

  #{{ section_id }} .aa-icon-item img {
    width: 44px;
    height: 44px;
    object-fit: contain;
  }

  #{{ section_id }} .aa-icon-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--aa-text);
    opacity: 0.75;
    line-height: 1.35;
  }

  /* Mobile */
  @media screen and (max-width: 768px) {
    #{{ section_id }} .aa-wrap {
      grid-template-columns: 1fr;
    }

    #{{ section_id }} .aa-image {
      min-height: 280px;
    }

    #{{ section_id }} .aa-image-placeholder {
      min-height: 280px;
    }

    #{{ section_id }} .aa-content {
      padding: 2rem 1.5rem;
    }

    #{{ section_id }} .aa-icons {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem 0;
    }

    #{{ section_id }} .aa-icon-item:nth-child(2) { border-right: none; }
    #{{ section_id }} .aa-icon-item:nth-child(3) { border-right: 1px solid var(--aa-border); }
    #{{ section_id }} .aa-icon-item:nth-child(3),
    #{{ section_id }} .aa-icon-item:nth-child(4) {
      border-top: 1px solid var(--aa-border);
      padding-top: 1rem;
    }
  }
</style>

<div id="{{ section_id }}">
  <div class="aa-wrap">

    <!-- Left: Image -->
    <div class="aa-image">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 900 }}"
          alt="{{ section.settings.image.alt | escape | default: shop.name }}"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
          loading="lazy"
        >
      {%- else -%}
        <div class="aa-image-placeholder">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    </div>

    <!-- Right: Content -->
    <div class="aa-content">

      {%- if section.settings.label != blank -%}
        <span class="aa-label">{{ section.settings.label }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="aa-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <!-- Decorative leaf divider -->
      <div class="aa-divider" aria-hidden="true">
        <svg viewBox="0 0 60 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M30 10 C24 2, 10 2, 2 10 C10 18, 24 18, 30 10Z" stroke="currentColor" stroke-width="1" fill="none"/>
          <path d="M30 10 C36 2, 50 2, 58 10 C50 18, 36 18, 30 10Z" stroke="currentColor" stroke-width="1" fill="none"/>
          <line x1="0" y1="10" x2="8" y2="10" stroke="currentColor" stroke-width="0.8"/>
          <line x1="52" y1="10" x2="60" y2="10" stroke="currentColor" stroke-width="0.8"/>
        </svg>
      </div>

      {%- if section.settings.body_text != blank -%}
        <div class="aa-body">{{ section.settings.body_text }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="aa-icons">
          {%- for block in section.blocks -%}
            {%- if block.type == 'icon_pillar' -%}
              <div class="aa-icon-item" {{ block.shopify_attributes }}>
                {%- if block.settings.icon_image != blank -%}
                  <img
                    src="{{ block.settings.icon_image | image_url: width: 88 }}"
                    alt="{{ block.settings.label | escape }}"
                    width="44"
                    height="44"
                    loading="lazy"
                  >
                {%- endif -%}
                {%- if block.settings.label != blank -%}
                  <span class="aa-icon-label">{{ block.settings.label }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "About Al'Ard",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label (above heading)",
      "default": "About AL'ARD"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "We are Palestinian;\nwe like to feed people"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>We are a third generation family-run company passionate about bringing the best of Palestinian artisanal food to your dining table.</p><p>We know that healthy food makes healthy bodies. Our company thrives on bringing together traditional knowledge and modern practices to provide you with nothing but the finest quality goods.</p>"
    },
    {
      "type": "header",
      "content": "Colours"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#efe3d0"
    },
    {
      "type": "color",
      "id": "card_color",
      "label": "Card background",
      "default": "#faf6ef"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text",
      "default": "#3a3530"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#2c3d1e"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent (label & divider)",
      "default": "#56642f"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "icon_pillar",
      "name": "Icon pillar",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Palestinian Heritage"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "About Al'Ard",
      "blocks": [
        { "type": "icon_pillar", "settings": { "label": "Palestinian Heritage" } },
        { "type": "icon_pillar", "settings": { "label": "Sustainable Farming" } },
        { "type": "icon_pillar", "settings": { "label": "Family Tradition" } },
        { "type": "icon_pillar", "settings": { "label": "Authentic Quality" } }
      ]
    }
  ]
}
{% endschema %}
