{{ 'section-break-fast-meaning.css' | asset_url | stylesheet_tag }}

<section
  class="break-fast-meaning section-{{ section.id }}"
  
>
  <div class="page-width break-fast-meaning__inner">
    <div class="break-fast-meaning__content">
      <h2 class="break-fast-meaning__heading">
        {{ section.settings.heading }}
      </h2>

      <div class="break-fast-meaning__body">
        {%- if section.settings.paragraph_1 != blank -%}
          <p>{{ section.settings.paragraph_1 }}</p>
        {%- endif -%}

        {%- if section.settings.paragraph_2 != blank -%}
          <p>{{ section.settings.paragraph_2 }}</p>
        {%- endif -%}

        {%- if section.settings.paragraph_3 != blank -%}
          <p>{{ section.settings.paragraph_3 }}</p>
        {%- endif -%}

        {%- if section.settings.tagline != blank -%}
          <p class="break-fast-meaning__tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_link }}"
          class="break-fast-meaning__button"
        >
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>

    <div class="break-fast-meaning__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            class: 'break-fast-meaning__image',
            alt: section.settings.image_alt | escape
        }}
      {%- else -%}
        <div class="break-fast-meaning__placeholder">
          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Break Fast With Meaning",
  "tag": "section",
  "class": "section section--break-fast-meaning",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#897048"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Break your fast with meaning"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Paragraph 1",
      "default": "Breaking your fast with a date is a Sunnah. This Ramadan, choose dates that reflect your values — care, integrity, and ethical sourcing."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Paragraph 2",
      "default": "Our 100% Palestinian Medjool dates are grown in Jericho on Palestinian-owned farms, cultivated with deep respect for the land and the people who tend it."
    },
    {
      "type": "textarea",
      "id": "paragraph_3",
      "label": "Paragraph 3",
      "default": "Let your good deeds extend to what you consume. Nourish your body and support Palestinian farmers with every bite."
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Let your table speak for justice."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Build Your Ramadan Box"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Ramadan dates and lanterns"
    }
  ],
  "presets": [
    {
      "name": "Break Fast With Meaning"
    }
  ]
}
{% endschema %}
