{{ 'section-dates-hero.css' | asset_url | stylesheet_tag }}

<section
  class="dates-certificates section-{{ section.id }}"
  style="background-color: {{ section.settings.background_color }};"
>
  <div class="dates-certificates__bg">
    <div class="page-width dates-certificates__inner">
      <h2 class="dates-certificates__heading">
        {{ section.settings.heading }}
      </h2>

      <div class="dates-certificates__logos">
        {%- for block in section.blocks -%}
          {%- if block.type == 'logo' -%}
            <div class="dates-certificates__logo" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 260
                  | image_tag:
                    loading: 'lazy',
                    class: 'dates-certificates__logo-image',
                    alt: block.settings.alt | escape
                }}
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Dates certificates banner",
  "tag": "section",
  "class": "section section--dates-certificates",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Certificates of Al-Ard Palestine"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#d0b24f"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Dates certificates banner",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}

