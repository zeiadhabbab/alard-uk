<section class="naturally-nutritious section-{{ section.id }}">
  <div class="page-width naturally-nutritious__inner">
    <div class="naturally-nutritious__header">
      <h2 class="naturally-nutritious__heading">Naturally Nutritious</h2>
      <p class="naturally-nutritious__subheading">Packed with essential nutrients and natural goodness in every date</p>
