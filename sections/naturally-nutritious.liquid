          <span class="nutrition-facts__calories-value">120</span>
        </div>

        <div class="nutrition-facts__header-row">
          <span></span>
          <span>%Daily Value*</span>
        </div>

        <div class="nutrition-facts__row">
          <span class="nutrition-facts__label">Total fat</span>
          <span class="nutrition-facts__amount">0 g</span>
          <span class="nutrition-facts__percent">0%</span>
        </div>
        <div class="nutrition-facts__row nutrition-facts__row--indent">
          <span class="nutrition-facts__label">Saturated Fat</span>
          <span class="nutrition-facts__amount">0 g</span>
          <span class="nutrition-facts__percent">0%</span>
        </div>
