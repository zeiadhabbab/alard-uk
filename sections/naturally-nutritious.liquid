          <span class="nutrition-facts__label">Cholesterol</span>
          <span class="nutrition-facts__amount">0 mg</span>
          <span class="nutrition-facts__percent">0%</span>
        </div>

        <div class="nutrition-facts__row">
          <span class="nutrition-facts__label">Sodium</span>
          <span class="nutrition-facts__amount">0 mg</span>
          <span class="nutrition-facts__percent">0%</span>
        </div>

        <div class="nutrition-facts__row">
          <span class="nutrition-facts__label">Total Carbohydrates</span>
          <span class="nutrition-facts__amount">31 g</span>
          <span class="nutrition-facts__percent">10%</span>
        </div>
        <div class="nutrition-facts__row nutrition-facts__row--indent">
          <span class="nutrition-facts__label">Dietary Fiber</span>
          <span class="nutrition-facts__amount">3 g</span>
          <span class="nutrition-facts__percent">12%</span>
        </div>
        <div class="nutrition-facts__row nutrition-facts__row--indent">
          <span class="nutrition-facts__label">Total Sugars</span>
          <span class="nutrition-facts__amount">29 g</span>
          <span class="nutrition-facts__percent"></span>
        </div>
        <div class="nutrition-facts__row nutrition-facts__row--indent">
          <span class="nutrition-facts__label">Includes Added Sugars</span>
          <span class="nutrition-facts__amount">0 g</span>
          <span class="nutrition-facts__percent">0%</span>
        </div>

        <div class="nutrition-facts__row">
          <span class="nutrition-facts__label">Protein</span>
          <span class="nutrition-facts__amount">0.9 g</span>
          <span class="nutrition-facts__percent"></span>
        </div>

        <div class="nutrition-facts__divider"></div>

        <div class="nutrition-facts__row">
          <span class="nutrition-facts__label">Vitamin D</span>
          <span class="nutrition-facts__amount">0 mcg</span>
          <span class="nutrition-facts__percent">0%</span>
        </div>
        <div class="nutrition-facts__row">
          <span class="nutrition-facts__label">Calcium</span>
          <span class="nutrition-facts__amount">30 mg</span>
          <span class="nutrition-facts__percent">2%</span>
