              </span>
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.text }}</p>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <div class="sl-story">
    <div class="sl-shell sl-story__grid">
      <div class="sl-story__content">
        <h2 class="sl-heading">{{ section.settings.story_heading }}</h2>
        <span class="sl-rule" aria-hidden="true"></span>
        <p class="sl-copy">{{ section.settings.story_text }}</p>
      </div>
    </div>
  </div>

  {%- if section.settings.show_about -%}
    <div class="sl-about">
      <div class="sl-shell">
        <div class="sl-about__card">

          <div class="sl-about__image">
            {%- if section.settings.about_image != blank -%}
              <img
                src="{{ section.settings.about_image | image_url: width: 900 }}"
                alt="{{ section.settings.about_image.alt | escape | default: shop.name }}"
                width="{{ section.settings.about_image.width }}"
                height="{{ section.settings.about_image.height }}"
                loading="lazy"
              >
            {%- else -%}
              <div class="sl-about__image-placeholder">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {%- endif -%}
          </div>

          <div class="sl-about__content">
            {%- if section.settings.about_label != blank -%}
              <span class="sl-about__label">{{ section.settings.about_label }}</span>
            {%- endif -%}

            {%- if section.settings.about_heading != blank -%}
              <h2 class="sl-about__heading">{{ section.settings.about_heading }}</h2>
            {%- endif -%}

            <div class="sl-about__divider" aria-hidden="true">
              <svg viewBox="0 0 60 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M30 10 C24 2, 10 2, 2 10 C10 18, 24 18, 30 10Z" stroke="currentColor" stroke-width="1" fill="none"/>
                <path d="M30 10 C36 2, 50 2, 58 10 C50 18, 36 18, 30 10Z" stroke="currentColor" stroke-width="1" fill="none"/>
              </svg>
            </div>

            {%- if section.settings.about_body != blank -%}
