{% comment %}
  Sign up landing page for Al'Ard.
  Assign templates/page.sign-up.json to a Shopify page to render this standalone signup experience.
{% endcomment %}

{%- liquid
  assign section_id = 'signup-landing-' | append: section.id
  assign has_app_blocks = false
  assign app_blocks = section.blocks | where: 'type', '@app'
  assign hero_app_block = app_blocks[0]

  for block in section.blocks
    if block.type == '@app'
      assign has_app_blocks = true
      break
    endif
  endfor
-%}

{%- style -%}
  {%- if section.settings.hide_theme_chrome -%}
   

    #MainContent {
      width: 100% !important;
      margin-top: 0 !important;
    }
  {%- endif -%}

  #{{ section_id }} {
    --sl-cream: {{ section.settings.background_color }};
    --sl-paper: #fbfaf7;
    --sl-olive: {{ section.settings.accent_color }};
    --sl-olive-dark: #4c5d29;
    --sl-red: #bf3334;
    --sl-gold: {{ section.settings.secondary_accent_color }};
    --sl-text: {{ section.settings.text_color }};
    --sl-muted: #7f7b73;
    --sl-border: rgba(105, 92, 67, 0.16);
    --sl-shadow: 0 16px 45px rgba(73, 58, 33, 0.09);
    --sl-page: min(1360px, calc(100vw - 40px));
    color: var(--sl-text);
    background:
      radial-gradient(circle at top right, rgba(255,255,255,0.86), transparent 28rem),
      linear-gradient(180deg, #f5ead8 0%, var(--sl-cream) 30%, #eee3d0 68%, #eee2ce 100%);
    font-family: var(--font-body-family);
    overflow: hidden;
  }

  #{{ section_id }} *,
  #{{ section_id }} *::before,
  #{{ section_id }} *::after {
    box-sizing: border-box;
  }

  #{{ section_id }} .sl-shell {
    width: var(--sl-page);
    margin: 0 auto;
  }

  #{{ section_id }} .sl-heading {
    margin: 0;
    color: var(--sl-olive);
    font-family: var(--font-heading-family);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.08;
  }

  #{{ section_id }} .sl-copy {
    margin: 0;
    color: var(--sl-muted);
    font-size: clamp(1.6rem, 1.15vw, 2rem);
    line-height: 1.45;
  }

  #{{ section_id }} .sl-rule {
    position: relative;
    display: block;
    width: min(100%, 270px);
    height: 1px;
    margin: 18px 0 22px;
    background: linear-gradient(90deg, var(--sl-red), rgba(191, 51, 52, 0));
  }

  #{{ section_id }} .sl-rule::before,
  #{{ section_id }} .sl-section-kicker::after {
    content: "";
    position: absolute;
    width: 11px;
    height: 11px;
    background: var(--sl-red);
    transform: rotate(45deg);
  }

  #{{ section_id }} .sl-rule::before {
    left: 0;
    top: -5px;
  }

  #{{ section_id }} .sl-hero {
    position: relative;
    min-height: 820px;
        padding: clamp(66px, 11vw, 161px) 0 84px;
    isolation: isolate;
  }

  #{{ section_id }} .sl-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      linear-gradient(90deg, rgba(239, 224, 200, 0.95) 0%, rgba(244, 234, 216, 0.78) 44%, rgba(244, 234, 216, 0.22) 70%),
      linear-gradient(135deg, rgba(107, 95, 69, 0.08), transparent 40%);
  }

  #{{ section_id }} .sl-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0.22;
    background-image:
      linear-gradient(rgba(102, 82, 49, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(102, 82, 49, 0.05) 1px, transparent 1px);
    background-size: 46px 46px;
    mask-image: linear-gradient(90deg, #000, transparent 62%);
  }

  #{{ section_id }} .sl-hero__grid {
    display: grid;
    grid-template-columns: minmax(360px, 560px) minmax(420px, 1fr);
    align-items: center;
    gap: clamp(34px, 6vw, 96px);
  }

  #{{ section_id }} .sl-hero__content {
    position: relative;
    z-index: 2;
  }

  #{{ section_id }} .sl-hero h1 {
    max-width: 570px;
    font-size: clamp(4.2rem, 4.9vw, 6.4rem);
  }

  #{{ section_id }} .sl-hero__text {
    max-width: 600px;
    color: var(--sl-text);
    font-size: clamp(1.7rem, 1.25vw, 2.2rem);
    line-height: 1.35;
  }

  #{{ section_id }} .sl-form {
    display: grid;
    gap: 16px;
    width: min(100%, 560px);
    margin-top: 32px;
  }

  #{{ section_id }} .sl-form--inline {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    width: min(100%, 760px);
    margin: 34px auto 0;
  }

  #{{ section_id }} .sl-form__field {
    position: relative;
    min-width: 0;
  }

  #{{ section_id }} .sl-form__icon {
    position: absolute;
    left: 18px;
    top: 50%;
    width: 20px;
    height: 20px;
    color: #8a93a1;
    transform: translateY(-50%);
    pointer-events: none;
  }

  #{{ section_id }} .sl-form input {
    width: 100%;
    min-height: 58px;
    padding: 0 18px 0 48px;
    border: 1px solid #dfe3e8;
    border-radius: 8px;
    background: #fff;
    color: var(--sl-text);
    font-family: var(--font-body-family);
    font-size: 1.6rem;
    box-shadow: 0 5px 16px rgba(70, 58, 37, 0.07);
    outline-offset: 3px;
  }

  #{{ section_id }} .sl-form input::placeholder {
    color: #9a9da4;
    opacity: 1;
  }

  #{{ section_id }} .sl-form__button {
    min-height: 58px;
    border: 0;
    border-radius: 8px;
    background: var(--sl-olive);
    color: #fff;
    font-family: var(--font-body-family);
    font-size: 1.6rem;
    font-weight: 700;
    cursor: pointer;
    transition: background-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
  }

  #{{ section_id }} .sl-form__button:hover,
  #{{ section_id }} .sl-form__button:focus-visible {
    background: var(--sl-olive-dark);
    box-shadow: 0 14px 28px rgba(79, 96, 45, 0.22);
    transform: translateY(-1px);
  }

  #{{ section_id }} .sl-form--inline .sl-form__button {
    grid-column: 1 / -1;
    background: var(--sl-gold);
  }

  #{{ section_id }} .sl-form--inline .sl-form__button:hover,
  #{{ section_id }} .sl-form--inline .sl-form__button:focus-visible {
    background: #c7a93d;
  }

  #{{ section_id }} .sl-note {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin: 18px 0 0;
    color: var(--sl-text);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.35;
  }

  #{{ section_id }} .sl-note svg {
    flex: 0 0 18px;
    width: 18px;
    height: 18px;
  }

  #{{ section_id }} .sl-app-blocks {
    display: grid;
    gap: 16px;
    width: min(100%, 560px);
    margin-top: 32px;
  }

  #{{ section_id }} .sl-app-block {
    width: 100%;
  }
 
  #{{ section_id }} .sl-app-blocks form[data-testid="form"] {
    display: grid;
    gap: 16px;
    width: 100%;
    max-width: none;
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
  }

  #{{ section_id }} .sl-app-blocks form[data-testid="form"] > div:has(shop-lead-capture) {
    display: none !important;
  }

  #{{ section_id }} .sl-app-blocks ._formFieldContainer_1mxsl_5,
  #{{ section_id }} .sl-app-blocks form[data-testid="form"] [class*="_formFieldContainer"] {
    position: relative;
    margin: 0;
  }

  #{{ section_id }} .sl-app-blocks form[data-testid="form"] [class*="_formFieldContainer"]::before {
    content: "";
    position: absolute;
    left: 18px;
    top: 50%;
    z-index: 2;
    width: 20px;
    height: 20px;
    background-color: #7d8798;
    transform: translateY(-50%);
    pointer-events: none;
  }

  #{{ section_id }} .sl-app-blocks form[data-testid="form"] [class*="_formFieldContainer"]:has(input[data-testid="field-first_name"])::before,
  #{{ section_id }} .sl-app-blocks form[data-testid="form"] [class*="_formFieldContainer"]:has(input#first_name)::before {
    mask: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 21a8 8 0 0 0-16 0' fill='none' stroke='black' stroke-width='2' stroke-linecap='round'/%3E%3Ccircle cx='12' cy='7' r='4' fill='none' stroke='black' stroke-width='2'/%3E%3C/svg%3E") center / contain no-repeat;
    -webkit-mask: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 21a8 8 0 0 0-16 0' fill='none' stroke='black' stroke-width='2' stroke-linecap='round'/%3E%3Ccircle cx='12' cy='7' r='4' fill='none' stroke='black' stroke-width='2'/%3E%3C/svg%3E") center / contain no-repeat;
  }

  #{{ section_id }} .sl-app-blocks form[data-testid="form"] [class*="_formFieldContainer"]:has(input[data-testid="field-email"])::before,
  #{{ section_id }} .sl-app-blocks form[data-testid="form"] [class*="_formFieldContainer"]:has(input#email)::before {
    mask: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Crect x='3' y='5' width='18' height='14' rx='2' fill='none' stroke='black' stroke-width='2'/%3E%3Cpath d='m3.5 7 8.5 6 8.5-6' fill='none' stroke='black' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E") center / contain no-repeat;
    -webkit-mask: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Crect x='3' y='5' width='18' height='14' rx='2' fill='none' stroke='black' stroke-width='2'/%3E%3Cpath d='m3.5 7 8.5 6 8.5-6' fill='none' stroke='black' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E") center / contain no-repeat;
  }

  #{{ section_id }} .sl-app-blocks input[data-testid^="field-"],
  #{{ section_id }} .sl-app-blocks form[data-testid="form"] input {
    width: 100% !important;
    min-height: 58px !important;
    padding: 0 18px 0 48px !important;
    border: 1px solid #dfe3e8 !important;
    border-radius: 8px !important;
    background: #fff !important;
    color: var(--sl-text) !important;
    font-family: var(--font-body-family) !important;
    font-size: 1.6rem !important;
    box-shadow: 0 5px 16px rgba(70, 58, 37, 0.07) !important;
    outline-offset: 3px;
  }

  #{{ section_id }} .sl-app-blocks label[id^="label-"],
  #{{ section_id }} .sl-app-blocks form[data-testid="form"] label {
    position: absolute !important;
    left: 48px !important;
    top: 50% !important;
    color: #9a9da4 !important;
    font-family: var(--font-body-family) !important;
    font-size: 1.6rem !important;
    line-height: 1 !important;
    transform: translateY(-50%) !important;
    transition: opacity 160ms ease, visibility 160ms ease !important;
    pointer-events: none;
  }

  #{{ section_id }} .sl-app-blocks input:focus + label,
  #{{ section_id }} .sl-app-blocks input:not(:placeholder-shown) + label {
    opacity: 0;
  }

  #{{ section_id }} .sl-app-blocks button[data-testid="btn-form-submit"],
  #{{ section_id }} .sl-app-blocks form[data-testid="form"] button[type="submit"] {
    width: 100% !important;
    min-height: 58px !important;
    border: 0 !important;
    border-radius: 8px !important;
    background: var(--sl-olive) !important;
    color: #fff !important;
    font-family: var(--font-body-family) !important;
    font-size: 1.6rem !important;
    font-weight: 700 !important;
    cursor: pointer;
    transition: background-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
  }

  #{{ section_id }} .sl-app-blocks button[data-testid="btn-form-submit"]:hover,
  #{{ section_id }} .sl-app-blocks button[data-testid="btn-form-submit"]:focus-visible,
  #{{ section_id }} .sl-app-blocks form[data-testid="form"] button[type="submit"]:hover,
  #{{ section_id }} .sl-app-blocks form[data-testid="form"] button[type="submit"]:focus-visible {
    background: var(--sl-olive-dark) !important;
    box-shadow: 0 14px 28px rgba(79, 96, 45, 0.22);
    transform: translateY(-1px);
  }

  #{{ section_id }} .sl-app-blocks shopify-forms-embed::part(form) {
    display: grid;
    gap: 16px;
    width: 100%;
    max-width: none;
  }

  #{{ section_id }} .sl-app-blocks shopify-forms-embed::part(input) {
    min-height: 58px;
    border-radius: 8px;
    font-family: var(--font-body-family);
    font-size: 1.6rem;
  }

  #{{ section_id }} .sl-app-blocks shopify-forms-embed::part(button) {
    min-height: 58px;
    border-radius: 8px;
    background: var(--sl-olive);
    color: #fff;
    font-family: var(--font-body-family);
    font-size: 1.6rem;
    font-weight: 700;
  }

  #{{ section_id }} .sl-app-blocks shopify-forms-embed::part(button):hover,
  #{{ section_id }} .sl-app-blocks shopify-forms-embed::part(button):focus-visible {
    background: var(--sl-olive-dark);
  }

  #{{ section_id }} .sl-hero__image {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    z-index: 0;
    width: 100%;
    min-height: 100%;
    margin: 0;
  }

  #{{ section_id }} .sl-hero__image img {
    display: block;
    width: 100%;
    min-height: 100%;
    object-fit: cover;
    object-position: bottom;
  }

  #{{ section_id }} .sl-center {
    text-align: center;
  }

  #{{ section_id }} .sl-section-kicker {
    position: relative;
    display: inline-block;
    width: 280px;
    max-width: 70vw;
    height: 1px;
    margin: 18px auto 18px;
    background: linear-gradient(90deg, transparent, rgba(191, 51, 52, 0.55), transparent);
  }

  #{{ section_id }} .sl-section-kicker::after {
    left: 50%;
    top: -5px;
    transform: translateX(-50%) rotate(45deg);
  }

  #{{ section_id }} .sl-benefits {
    padding: clamp(58px, 7vw, 94px) 0 clamp(54px, 7vw, 88px);
  }

  #{{ section_id }} .sl-benefits h2,
  #{{ section_id }} .sl-story h2,
  #{{ section_id }} .sl-community h2 {
    font-size: clamp(3.6rem, 3.2vw, 5.2rem);
  }

  #{{ section_id }} .sl-benefits__subtitle {
    color: var(--sl-muted);
    font-size: 2rem;
  }

  #{{ section_id }} .sl-benefits__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(20px, 2vw, 28px);
    margin-top: 34px;
  }

  #{{ section_id }} .sl-benefit {
    min-height: 286px;
    padding: 38px 28px 32px;
    border: 1px solid var(--sl-border);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: var(--sl-shadow);
    text-align: center;
  }

  #{{ section_id }} .sl-benefit__icon {
    display: inline-grid;
    width: 92px;
    height: 92px;
    margin-bottom: 22px;
    place-items: center;
  }

  #{{ section_id }} .sl-benefit h3 {
    margin: 0 0 10px;
    color: var(--sl-olive);
    font-family: var(--font-heading-family);
    font-size: clamp(2.4rem, 2.2vw, 3.2rem);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.1;
  }

  #{{ section_id }} .sl-benefit p {
    max-width: 310px;
    margin: 0 auto;
    color: var(--sl-muted);
    font-size: 1.55rem;
    line-height: 1.38;
  }

  #{{ section_id }} .sl-story {
    position: relative;
    min-height: 480px;
    padding: clamp(70px, 10vw, 146px) 0 clamp(78px, 10vw, 150px);
    isolation: isolate;
  }

  #{{ section_id }} .sl-story__grid {
    display: grid;
    grid-template-columns: minmax(320px, 560px) 1fr;
    align-items: center;
    gap: clamp(32px, 7vw, 96px);
  }

  #{{ section_id }} .sl-story__image {
    position: absolute;
    right: 0;
    bottom: 0;
    z-index: -1;
    width: min(58vw, 860px);
  }

  #{{ section_id }} .sl-story__image::before {
    content: "";
    position: absolute;
    inset: -1px 42% -1px -1px;
    z-index: 1;
    background: linear-gradient(90deg, var(--sl-cream), rgba(239, 227, 207, 0));
  }

  #{{ section_id }} .sl-story__image img {
    display: block;
    width: 100%;
    object-fit: cover;
  }

  #{{ section_id }} .sl-story__content {
    position: relative;
    z-index: 2;
  }

  #{{ section_id }} .sl-story .sl-copy {
    max-width: 640px;
    color: var(--sl-muted);
    font-size: clamp(1.8rem, 1.4vw, 2.3rem);
  }

  #{{ section_id }} .sl-community {
    position: relative;
    padding: clamp(58px, 7vw, 82px) 0 clamp(58px, 7vw, 86px);
    background: var(--sl-olive);
    color: #fff;
    text-align: center;
    isolation: isolate;
  }

  #{{ section_id }} .sl-community::before,
  #{{ section_id }} .sl-community::after {
    content: "";
    position: absolute;
    inset: 0 auto 0 0;
    z-index: -1;
    width: min(27vw, 318px);
    opacity: 0.22;
    background-position: left;
    {%- if section.settings.community_pattern_image != blank -%}
      background: url({{ section.settings.community_pattern_image | image_url: width: 700 }}) center / contain no-repeat;
    {%- else -%}
    background:
      linear-gradient(45deg, transparent 46%, rgba(255,255,255,0.38) 47% 53%, transparent 54%) 0 0 / 34px 34px,
      repeating-linear-gradient(90deg, rgba(255,255,255,0.18) 0 5px, transparent 5px 14px);
    {%- endif -%}
  }

  #{{ section_id }} .sl-community::after {
    right: 0;
    left: auto;
    transform: scaleX(-1);
  }

  #{{ section_id }} .sl-community .sl-heading {
    color: #fff;
  }

  #{{ section_id }} .sl-community .sl-copy {
    color: rgba(255, 255, 255, 0.86);
    font-size: 1.9rem;
  }

  #{{ section_id }} .sl-community .sl-note {
    justify-content: center;
    max-width: 760px;
    margin: 20px auto 0;
    color: rgba(255, 255, 255, 0.86);
  }

  #{{ section_id }} .sl-message {
    margin: 6px 0 0;
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.35;
  }

  #{{ section_id }} .sl-message--error {
    color: #a41f20;
  }

  #{{ section_id }} .sl-community .sl-message--error {
    color: #ffd3d3;
  }

  #{{ section_id }} .sl-message--success {
    color: var(--sl-olive);
  }

  #{{ section_id }} .sl-community .sl-message--success {
    color: #fff;
  }

  #{{ section_id }} .sl-trust {
    padding: 22px 0;
    background: #aa7600;
    color: #fff;
  }

  #{{ section_id }} .sl-trust__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 22px;
  }

  #{{ section_id }} .sl-trust__item {
    display: grid;
    grid-template-columns: 42px minmax(0, 1fr);
    align-items: center;
    gap: 14px;
    min-width: 0;
  }

  #{{ section_id }} .sl-trust__icon {
    display: inline-grid;
    width: 42px;
    height: 42px;
    place-items: center;
    border-radius: 50%;
    background: #fff;
    color: #aa7600;
  }

  #{{ section_id }} .sl-trust__icon svg {
    width: 25px;
    height: 25px;
  }

  #{{ section_id }} .sl-trust h3 {
    margin: 0 0 3px;
    color: #fff;
    font-size: 1.6rem;
    font-weight: 800;
    line-height: 1.1;
  }

  #{{ section_id }} .sl-trust p {
    margin: 0;
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.25;
  }

  @media screen and (max-width: 989px) {
    #{{ section_id }} {
      --sl-page: min(100% - 28px, 760px);
    }

    #{{ section_id }} .sl-hero {
      min-height: auto;
      padding-top: 184px;
    }

    #{{ section_id }} .sl-hero__grid,
    #{{ section_id }} .sl-story__grid {
      grid-template-columns: 1fr;
    }

    #{{ section_id }} .sl-hero__image {
      margin: 0;
    }

    #{{ section_id }} .sl-benefits__grid,
    #{{ section_id }} .sl-trust__grid {
      grid-template-columns: 1fr 1fr;
    }

    #{{ section_id }} .sl-story {
      padding-bottom: 0;
    }

    #{{ section_id }} .sl-story__image {
      position: relative;
      right: auto;
      width: calc(100% + 28px);
      margin: 34px -14px 0;
    }

    #{{ section_id }} .sl-story__image::before {
      inset: 0 0 auto;
      height: 44%;
      background: linear-gradient(180deg, var(--sl-cream), rgba(239, 227, 207, 0));
    }
  }

  @media screen and (max-width: 640px) {
    #{{ section_id }} .sl-hero h1 {
      font-size: 4rem;
    }

    #{{ section_id }} .sl-form,
    #{{ section_id }} .sl-form--inline {
      grid-template-columns: 1fr;
      width: 100%;
    }

    #{{ section_id }} .sl-benefits__grid,
    #{{ section_id }} .sl-trust__grid {
      grid-template-columns: 1fr;
    }

    #{{ section_id }} .sl-benefit {
      min-height: auto;
      padding: 30px 22px;
    }

    #{{ section_id }} .sl-community::before,
    #{{ section_id }} .sl-community::after {
      width: 42vw;
    }
  }

  .sl-story {
    background: url({{ 'signup-story-food.png' | asset_url }});
    background-position: right;
    background-repeat: no-repeat;
    background-size: contain;
}

  /* ── Early Access Banner ── */
  #{{ section_id }} .sl-ea {
    padding: 12px 0 36px;
    background: transparent;
  }

  #{{ section_id }} .sl-ea > .sl-shell {
    width: min(1120px, calc(100vw - 32px));
  }

  #{{ section_id }} .sl-ea__inner {
    position: relative;
    display: grid;
    grid-template-columns: 176px minmax(0, 1fr);
    grid-template-areas:
      "deco text"
      "deco form";
    align-items: center;
    column-gap: clamp(2rem, 4.2vw, 6.2rem);
    row-gap: 12px;
    min-height: 126px;
    padding: 18px clamp(24px, 5.2vw, 78px) 14px clamp(18px, 3vw, 34px);
    overflow: hidden;
    border: 1px solid rgba(94, 91, 64, 0.08);
    border-radius: 9px;
    background:
      linear-gradient(90deg, rgba(226, 219, 193, 0.74), rgba(239, 235, 213, 0.94) 40%, rgba(226, 219, 193, 0.76)),
      #e8e3cb;
    box-shadow: 0 8px 22px rgba(82, 70, 45, 0.06);
  }

  #{{ section_id }} .sl-ea__deco {
    grid-area: deco;
    display: flex;
    align-items: center;
    justify-content: center;
    align-self: stretch;
  }

  #{{ section_id }} .sl-ea__deco svg {
    width: min(100%, 156px);
    height: auto;
    margin: -22px 0 -12px -16px;
    opacity: 0.92;
    transform: rotate(-11deg);
    transform-origin: center;
  }

  #{{ section_id }} .sl-ea__text {
    grid-area: text;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    max-width: 710px;
    margin: 0 auto;
    text-align: center;
  }

  #{{ section_id }} .sl-ea__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(1.95rem, 1.85vw, 2.35rem);
    font-weight: 700;
    color: #2c3d1e;
    margin: 0;
    line-height: 1.14;
  }

  #{{ section_id }} .sl-ea__subtext {
    max-width: 570px;
    font-size: clamp(1rem, 0.82vw, 1.16rem);
    color: #2f321f;
    margin: 0;
    line-height: 1.32;
  }

  #{{ section_id }} .sl-ea__form-wrap {
    grid-area: form;
    width: min(100%, 650px);
    min-width: 0;
    margin: 0 auto;
  }

  #{{ section_id }} .sl-ea-form {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) 170px;
    gap: 12px;
    align-items: center;
    width: 100%;
    margin: 0;
  }

  #{{ section_id }} .sl-ea-form__field {
    position: relative;
    min-width: 0;
  }

  #{{ section_id }} .sl-ea-form__icon {
    position: absolute;
    left: 13px;
    top: 50%;
    z-index: 2;
    width: 14px;
    height: 14px;
    color: #8c9188;
    transform: translateY(-50%);
    pointer-events: none;
  }

  #{{ section_id }} .sl-ea-form input {
    width: 100%;
    height: 34px;
    min-height: 34px;
    padding: 0 12px 0 34px;
    border: 1px solid rgba(200, 202, 190, 0.9);
    border-radius: 3px;
    background: #fff;
    color: var(--sl-text);
    font-family: var(--font-body-family);
    font-size: 1rem;
    line-height: 34px;
    box-shadow: none;
    outline-offset: 2px;
  }

  #{{ section_id }} .sl-ea-form input::placeholder {
    color: #676b63;
    opacity: 1;
  }

  #{{ section_id }} .sl-ea-form__button {
    width: 100%;
    height: 34px;
    min-height: 34px;
    white-space: nowrap;
    padding: 0 1.4rem;
    border: 0;
    border-radius: 4px;
    background: var(--sl-olive);
    color: #fff;
    font-family: var(--font-body-family);
    font-size: 1rem;
    line-height: 34px;
    font-weight: 700;
    cursor: pointer;
    box-shadow: none;
    transition: background-color 160ms ease;
  }

  #{{ section_id }} .sl-ea-form__button:hover,
  #{{ section_id }} .sl-ea-form__button:focus-visible {
    background: var(--sl-olive-dark);
  }

  #{{ section_id }} .sl-ea-form .sl-message {
    grid-column: 1 / -1;
    margin: -4px 0 0;
    font-size: 1.1rem;
    line-height: 1.25;
    text-align: center;
  }

  @media screen and (max-width: 989px) {
    #{{ section_id }} .sl-ea__inner {
      grid-template-columns: 1fr;
      grid-template-areas:
        "deco"
        "text"
        "form";
      min-height: 0;
      padding: 26px 18px 22px;
      text-align: center;
    }

    #{{ section_id }} .sl-ea__deco {
      max-height: 78px;
      overflow: hidden;
    }

    #{{ section_id }} .sl-ea__deco svg {
      width: 128px;
      margin: -34px auto -16px;
    }

    #{{ section_id }} .sl-ea__form-wrap {
      min-width: 0;
      width: 100%;
    }

    #{{ section_id }} .sl-ea-form {
      grid-template-columns: 1fr;
    }
  }

  /* ── About Al'Ard ── */
  #{{ section_id }} .sl-about {
    padding: 60px 0 60px;
    background-color: var(--sl-cream);
  }

  #{{ section_id }} .sl-about__card {
    background: {{ section.settings.about_card_color }};
    border: 1px solid var(--sl-border);
    border-radius: 20px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 520px;
  }

  #{{ section_id }} .sl-about__image {
    position: relative;
    overflow: hidden;
  }

  #{{ section_id }} .sl-about__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #{{ section_id }} .sl-about__image-placeholder {
    width: 100%;
    height: 100%;
    min-height: 400px;
    background: #ddd3bb;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #9e8f78;
  }

  #{{ section_id }} .sl-about__content {
    padding: 3.5rem 3rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.25rem;
    color: {{ section.settings.about_text_color }};
  }

  #{{ section_id }} .sl-about__label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: {{ section.settings.about_accent_color }};
    font-size: 2.25rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  #{{ section_id }} .sl-about__label::before {
    content: '';
    width: 0.4rem;
    height: 1px;
    background: currentColor;
    opacity: 0.6;
  }

  #{{ section_id }} .sl-about__label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: currentColor;
    opacity: 0.3;
    max-width: 2rem;
  }

  #{{ section_id }} .sl-about__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(5rem, 7vw, 4.4rem);
    font-weight: 700;
    line-height: 1.15;
    color: {{ section.settings.about_heading_color }};
    margin: 0;
    white-space: pre-line;
  }

  #{{ section_id }} .sl-about__divider {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: {{ section.settings.about_accent_color }};
    opacity: 0.5;
  }

  #{{ section_id }} .sl-about__divider::before,
  #{{ section_id }} .sl-about__divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: currentColor;
    max-width: 2.5rem;
  }

  #{{ section_id }} .sl-about__divider svg {
    width: 22px;
    height: 14px;
    flex-shrink: 0;
  }

  #{{ section_id }} .sl-about__body {
    font-size: 1.91rem;
    line-height: 1.75;
    color: {{ section.settings.about_text_color }};
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  #{{ section_id }} .sl-about__body p { margin: 0; }

  #{{ section_id }} .sl-about__icons {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--sl-border);
    margin-top: 0.5rem;
    padding-top: 1.25rem;
  }

  #{{ section_id }} .sl-about__icon-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    border-right: 8px solid rgb(251 246 239);
    text-align: center;
    background: #f6eee4;
    border-radius: 17px;
  }

  #{{ section_id }} .sl-about__icon-item:last-child { border-right: 8px solid rgb(251 246 239); }

  #{{ section_id }} .sl-about__icon-item img {
    width: 90px;
    height: 90px;
    object-fit: contain;
  }

  #{{ section_id }} .sl-about__icon-label {
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: {{ section.settings.about_text_color }};
    opacity: 0.7;
    line-height: 1.3;
    padding: 0 11px 15px;
  }

  @media screen and (max-width: 768px) {
    #{{ section_id }} .sl-about__card {
      grid-template-columns: 1fr;
    }

    #{{ section_id }} .sl-about__image {
      min-height: 260px;
    }

    #{{ section_id }} .sl-about__content {
      padding: 2rem 1.5rem;
    }

    #{{ section_id }} .sl-about__icons {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem 0;
    }

    #{{ section_id }} .sl-about__icon-item:nth-child(2) { border-right: none; }
    #{{ section_id }} .sl-about__icon-item:nth-child(3) { border-right: 1px solid var(--sl-border); }
    #{{ section_id }} .sl-about__icon-item:nth-child(3),
    #{{ section_id }} .sl-about__icon-item:nth-child(4) {
      border-top: 1px solid var(--sl-border);
      padding-top: 1rem;
    }
  }
{%- endstyle -%}

<section id="{{ section_id }}" class="sl-page" aria-label="{{ section.settings.section_label | escape }}">
  <div class="sl-hero">
    <div class="sl-shell sl-hero__grid">
      <div class="sl-hero__content">
        <h1 class="sl-heading">{{ section.settings.hero_heading }}</h1>
        <span class="sl-rule" aria-hidden="true"></span>
        <p class="sl-hero__text">{{ section.settings.hero_text }}</p>

        {%- if has_app_blocks -%}
          <div class="sl-app-blocks">
            {%- if hero_app_block -%}
              <div class="sl-app-block" {{ hero_app_block.shopify_attributes }}>
                {% render hero_app_block %}
              </div>
            {%- endif -%}
          </div>
        {%- else -%}
          {% form 'customer', class: 'sl-form' %}
            <input type="hidden" name="contact[tags]" value="{{ section.settings.customer_tags | escape }}">
            <div class="sl-form__field">
              <label class="visually-hidden" for="SignupLandingHeroFirstName-{{ section.id }}">{{ section.settings.first_name_placeholder }}</label>
              <svg class="sl-form__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M20 21a8 8 0 0 0-16 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2"/>
              </svg>
              <input
                id="SignupLandingHeroFirstName-{{ section.id }}"
                type="text"
                name="contact[first_name]"
                autocomplete="given-name"
                placeholder="{{ section.settings.first_name_placeholder | escape }}"
              >
            </div>

            <div class="sl-form__field">
              <label class="visually-hidden" for="SignupLandingHeroEmail-{{ section.id }}">{{ section.settings.email_placeholder }}</label>
              <svg class="sl-form__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="2"/>
                <path d="m3.5 7 8.5 6 8.5-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <input
                id="SignupLandingHeroEmail-{{ section.id }}"
                type="email"
                name="contact[email]"
                value="{{ form.email }}"
                autocomplete="email"
                autocorrect="off"
                autocapitalize="off"
                placeholder="{{ section.settings.email_placeholder | escape }}"
                required
                {% if form.errors %}
                  aria-invalid="true"
                  aria-describedby="SignupLandingHeroError-{{ section.id }}"
                {% elsif form.posted_successfully? %}
                  aria-describedby="SignupLandingHeroSuccess-{{ section.id }}"
                {% endif %}
              >
            </div>

            <button type="submit" class="sl-form__button" name="commit">
              {{ section.settings.hero_button_label | escape }}
            </button>

            {%- if form.errors -%}
              <p class="sl-message sl-message--error" id="SignupLandingHeroError-{{ section.id }}">
                {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
              </p>
            {%- endif -%}

            {%- if form.posted_successfully? -%}
              <p class="sl-message sl-message--success" id="SignupLandingHeroSuccess-{{ section.id }}" tabindex="-1">
                {{ section.settings.success_message }}
              </p>
            {%- endif -%}
          {% endform %}
        {%- endif -%}

        <p class="sl-note">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
            <path d="m9 12 2 2 4-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          {{ section.settings.assurance_text }}
        </p>
      </div>

      <figure class="sl-hero__image">
        {%- if section.settings.hero_image != blank -%}
          {{
            section.settings.hero_image
            | image_url: width: 1500
            | image_tag:
              widths: '600, 900, 1200, 1500',
              sizes: '(min-width: 990px) 52vw, 100vw',
              loading: 'eager',
              alt: section.settings.hero_image.alt
          }}
        {%- else -%}
          <img
            src="{{ 'signup-hero-products.png' | asset_url }}"
            alt=""
            width="1360"
            height="1160"
            loading="eager"
          >
        {%- endif -%}
      </figure>
    </div>
  </div>

  <div class="sl-benefits">
    <div class="sl-shell sl-center">
      <h2 class="sl-heading">{{ section.settings.benefits_heading }}</h2>
      <span class="sl-section-kicker" aria-hidden="true"></span>
      <p class="sl-benefits__subtitle">{{ section.settings.benefits_subheading }}</p>

      <div class="sl-benefits__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'benefit' -%}
            <article class="sl-benefit" {{ block.shopify_attributes }}>
              <span class="sl-benefit__icon" aria-hidden="true">
                {%- case block.settings.icon -%}
                  {%- when 'tag' -%}
<svg width="96" height="96" viewBox="0 0 96 96" fill="none" xmlns="http://www.w3.org/2000/svg">
<rect x="2" y="2" width="92" height="92" rx="46" stroke="#56622E" stroke-width="4"/>
