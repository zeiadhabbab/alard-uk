      "id": "story_image",
      "label": "Story image"
    },
    {
      "type": "header",
      "content": "Community signup"
    },
    {
      "type": "inline_richtext",
      "id": "community_heading",
      "label": "Heading",
      "default": "Join the Al'Ard Europe Community"
    },
