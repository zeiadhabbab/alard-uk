                        src="{{ block.settings.icon_image | image_url: width: 88 }}"
                        alt="{{ block.settings.label | escape }}"
                        width="42"
                        height="42"
                        loading="lazy"
                      >
                    {%- endif -%}
                    {%- if block.settings.label != blank -%}
                      <span class="sl-about__icon-label">{{ block.settings.label }}</span>
                    {%- endif -%}
                  </div>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>

        </div>
      </div>
    </div>
  {%- endif -%}

  {%- if section.settings.show_early_access -%}
    <div class="sl-ea">
      <div class="sl-shell">
        <div class="sl-ea__inner">

          <div class="sl-ea__deco" aria-hidden="true">
            <svg viewBox="0 0 180 150" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 133 C48 104 76 79 111 53 C129 40 145 29 163 17" stroke="#6f6d4b" stroke-width="3.2" stroke-linecap="round"/>
              <path d="M43 109 C31 101 23 91 18 77" stroke="#6f6d4b" stroke-width="1.6" stroke-linecap="round"/>
              <path d="M58 94 C51 82 47 70 47 55" stroke="#6f6d4b" stroke-width="1.6" stroke-linecap="round"/>
              <path d="M75 80 C68 68 65 55 67 40" stroke="#6f6d4b" stroke-width="1.6" stroke-linecap="round"/>
              <path d="M94 65 C88 54 87 41 91 27" stroke="#6f6d4b" stroke-width="1.6" stroke-linecap="round"/>
              <path d="M111 52 C106 41 107 30 112 19" stroke="#6f6d4b" stroke-width="1.6" stroke-linecap="round"/>
              <path d="M46 108 C58 110 71 108 83 101" stroke="#6f6d4b" stroke-width="1.6" stroke-linecap="round"/>
              <path d="M65 91 C78 93 91 89 102 81" stroke="#6f6d4b" stroke-width="1.6" stroke-linecap="round"/>
              <path d="M84 76 C98 77 110 72 120 62" stroke="#6f6d4b" stroke-width="1.6" stroke-linecap="round"/>
              <path d="M103 61 C116 60 127 55 136 44" stroke="#6f6d4b" stroke-width="1.6" stroke-linecap="round"/>
              <path d="M122 47 C133 45 143 39 151 30" stroke="#6f6d4b" stroke-width="1.6" stroke-linecap="round"/>

              <ellipse cx="20" cy="74" rx="7" ry="22" transform="rotate(-30 20 74)" fill="#858660"/>
              <ellipse cx="48" cy="54" rx="7" ry="22" transform="rotate(-6 48 54)" fill="#858660"/>
              <ellipse cx="69" cy="38" rx="7" ry="21" transform="rotate(6 69 38)" fill="#858660"/>
              <ellipse cx="93" cy="26" rx="6.5" ry="19" transform="rotate(15 93 26)" fill="#858660"/>
              <ellipse cx="115" cy="19" rx="6" ry="17" transform="rotate(24 115 19)" fill="#858660"/>
              <ellipse cx="83" cy="100" rx="7" ry="22" transform="rotate(63 83 100)" fill="#858660"/>
              <ellipse cx="103" cy="81" rx="7" ry="21" transform="rotate(57 103 81)" fill="#858660"/>
              <ellipse cx="121" cy="62" rx="6.5" ry="20" transform="rotate(50 121 62)" fill="#858660"/>
              <ellipse cx="136" cy="44" rx="6" ry="18" transform="rotate(45 136 44)" fill="#858660"/>
              <ellipse cx="151" cy="30" rx="5.5" ry="16" transform="rotate(41 151 30)" fill="#858660"/>

              <circle cx="39" cy="116" r="9" fill="#8b8242"/>
              <circle cx="47" cy="112" r="6.5" fill="#b5a44a"/>
              <circle cx="56" cy="99" r="7" fill="#6f742e"/>
              <circle cx="112" cy="58" r="5.5" fill="#a99842"/>
              <circle cx="126" cy="47" r="5" fill="#77772e"/>
            </svg>
          </div>

          <div class="sl-ea__text">
            <h2 class="sl-ea__heading">{{ section.settings.ea_heading }}</h2>
            {%- if section.settings.ea_subtext != blank -%}
              <p class="sl-ea__subtext">{{ section.settings.ea_subtext }}</p>
            {%- endif -%}
          </div>

          <div class="sl-ea__form-wrap">
            {% form 'customer', id: 'SignupLandingEarlyAccess', class: 'sl-ea-form' %}
              <input type="hidden" name="contact[tags]" value="{{ section.settings.customer_tags | escape }}">

              <div class="sl-ea-form__field">
                <label class="visually-hidden" for="SignupLandingEarlyAccessFirstName-{{ section.id }}">{{ section.settings.first_name_placeholder }}</label>
                <svg class="sl-ea-form__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M20 21a8 8 0 0 0-16 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2"/>
                </svg>
                <input
                  id="SignupLandingEarlyAccessFirstName-{{ section.id }}"
                  type="text"
                  name="contact[first_name]"
                  autocomplete="given-name"
                  placeholder="{{ section.settings.first_name_placeholder | escape }}"
                >
              </div>

              <div class="sl-ea-form__field">
                <label class="visually-hidden" for="SignupLandingEarlyAccessEmail-{{ section.id }}">{{ section.settings.email_placeholder }}</label>
                <svg class="sl-ea-form__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="2"/>
                  <path d="m3.5 7 8.5 6 8.5-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <input
                  id="SignupLandingEarlyAccessEmail-{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  value="{{ form.email }}"
                  autocomplete="email"
                  autocorrect="off"
                  autocapitalize="off"
                  placeholder="{{ section.settings.email_placeholder | escape }}"
                  required
                  {% if form.errors %}
                    aria-invalid="true"
                    aria-describedby="SignupLandingEarlyAccessError-{{ section.id }}"
                  {% elsif form.posted_successfully? %}
                    aria-describedby="SignupLandingEarlyAccessSuccess-{{ section.id }}"
                  {% endif %}
                >
              </div>

              <button type="submit" class="sl-ea-form__button" name="commit">
                {{ section.settings.ea_button_label | default: 'Join the List' | escape }}
              </button>

              {%- if form.errors -%}
                <p class="sl-message sl-message--error" id="SignupLandingEarlyAccessError-{{ section.id }}">
                  {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
                </p>
              {%- endif -%}

              {%- if form.posted_successfully? -%}
                <p class="sl-message sl-message--success" id="SignupLandingEarlyAccessSuccess-{{ section.id }}" tabindex="-1">
                  {{ section.settings.success_message }}
                </p>
              {%- endif -%}
            {% endform %}
          </div>

        </div>
      </div>
    </div>
  {%- endif -%}

  <div class="sl-community">
    <div class="sl-shell">
      <h2 class="sl-heading">{{ section.settings.community_heading }}</h2>
      <span class="sl-section-kicker" aria-hidden="true"></span>
      <p class="sl-copy">{{ section.settings.community_text }}</p>

      {% form 'customer', id: 'SignupLandingCommunity', class: 'sl-form sl-form--inline' %}
        <input type="hidden" name="contact[tags]" value="{{ section.settings.customer_tags | escape }}">
        <div class="sl-form__field">
          <label class="visually-hidden" for="SignupLandingCommunityFirstName-{{ section.id }}">{{ section.settings.first_name_placeholder }}</label>
          <svg class="sl-form__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M20 21a8 8 0 0 0-16 0" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2"/>
          </svg>
          <input
            id="SignupLandingCommunityFirstName-{{ section.id }}"
            type="text"
            name="contact[first_name]"
            autocomplete="given-name"
            placeholder="{{ section.settings.first_name_placeholder | escape }}"
          >
        </div>

        <div class="sl-form__field">
          <label class="visually-hidden" for="SignupLandingCommunityEmail-{{ section.id }}">{{ section.settings.email_placeholder }}</label>
          <svg class="sl-form__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="2"/>
            <path d="m3.5 7 8.5 6 8.5-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <input
            id="SignupLandingCommunityEmail-{{ section.id }}"
            type="email"
            name="contact[email]"
            value="{{ form.email }}"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            placeholder="{{ section.settings.email_placeholder | escape }}"
            required
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="SignupLandingCommunityError-{{ section.id }}"
            {% elsif form.posted_successfully? %}
              aria-describedby="SignupLandingCommunitySuccess-{{ section.id }}"
            {% endif %}
          >
        </div>

        <button type="submit" class="sl-form__button" name="commit">
          {{ section.settings.community_button_label | escape }}
        </button>

        {%- if form.errors -%}
          <p class="sl-message sl-message--error" id="SignupLandingCommunityError-{{ section.id }}">
            {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
          </p>
        {%- endif -%}

        {%- if form.posted_successfully? -%}
          <p class="sl-message sl-message--success" id="SignupLandingCommunitySuccess-{{ section.id }}" tabindex="-1">
            {{ section.settings.success_message }}
          </p>
        {%- endif -%}
      {% endform %}

      <p class="sl-note">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
          <path d="m9 12 2 2 4-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {{ section.settings.assurance_text }}
      </p>
    </div>
  </div>

  {%- if section.settings.show_trust_bar -%}
    <div class="sl-trust">
      <div class="sl-shell sl-trust__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust_item' -%}
            <div class="sl-trust__item" {{ block.shopify_attributes }}>
              <span class="sl-trust__icon" aria-hidden="true">
                {%- case block.settings.icon -%}
                  {%- when 'truck' -%}
                    <svg viewBox="0 0 24 24" fill="none"><path d="M3 7h11v10H3V7Zm11 3h4l3 3v4h-7v-7Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><circle cx="7" cy="18" r="2" stroke="currentColor" stroke-width="2"/><circle cx="18" cy="18" r="2" stroke="currentColor" stroke-width="2"/></svg>
                  {%- when 'bolt' -%}
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="m13 2-9 12h7l-1 8 10-13h-7l0-7Z"/></svg>
                  {%- when 'quality' -%}
                    <svg viewBox="0 0 24 24" fill="none"><path d="M12 3 4 6v6c0 5 3.4 8.2 8 9 4.6-.8 8-4 8-9V6l-8-3Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="m8.8 12 2.1 2.1 4.5-4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {%- else -%}
                    <svg viewBox="0 0 24 24" fill="none"><path d="M20 4C11 4 5 9.6 5 17.5V20h2.5C15.4 20 21 14 21 5V4h-1Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/><path d="M5 19c3.5-5.5 7-8.5 12-10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                {%- endcase -%}
              </span>
              <div>
                <h3>{{ block.settings.title }}</h3>
                <p>{{ block.settings.text }}</p>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

<script>
  (() => {
    const section = document.getElementById({{ section_id | json }});
    if (!section) return;

    const computed = window.getComputedStyle(section);
    const olive = computed.getPropertyValue('--sl-olive').trim() || '#56642f';
    const oliveDark = computed.getPropertyValue('--sl-olive-dark').trim() || '#4c5d29';
    const textColor = computed.getPropertyValue('--sl-text').trim() || '#202020';
    const bodyFont = computed.getPropertyValue('--font-body-family').trim() || 'inherit';
    const styleId = 'sl-shopify-forms-style';
    const formCss = `
      form[data-testid="form"] {
        display: grid !important;
        gap: 16px !important;
        width: 100% !important;
        max-width: none !important;
        margin: 0 !important;
        padding: 0 !important;
        border: 0 !important;
        background: transparent !important;
      }

      form[data-testid="form"] > div:has(shop-lead-capture) {
        display: none !important;
      }

      form[data-testid="form"] [class*="_formFieldContainer"] {
        position: relative !important;
        margin: 0 !important;
      }

      form[data-testid="form"] [class*="_formFieldContainer"]::before {
        content: "" !important;
        position: absolute !important;
        left: 18px !important;
        top: 50% !important;
        z-index: 2 !important;
        width: 20px !important;
        height: 20px !important;
        background-color: #7d8798 !important;
        transform: translateY(-50%) !important;
        pointer-events: none !important;
      }

      form[data-testid="form"] [class*="_formFieldContainer"]:has(input[data-testid="field-first_name"])::before,
      form[data-testid="form"] [class*="_formFieldContainer"]:has(input#first_name)::before {
        mask: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 21a8 8 0 0 0-16 0' fill='none' stroke='black' stroke-width='2' stroke-linecap='round'/%3E%3Ccircle cx='12' cy='7' r='4' fill='none' stroke='black' stroke-width='2'/%3E%3C/svg%3E") center / contain no-repeat !important;
        -webkit-mask: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M20 21a8 8 0 0 0-16 0' fill='none' stroke='black' stroke-width='2' stroke-linecap='round'/%3E%3Ccircle cx='12' cy='7' r='4' fill='none' stroke='black' stroke-width='2'/%3E%3C/svg%3E") center / contain no-repeat !important;
      }

      form[data-testid="form"] [class*="_formFieldContainer"]:has(input[data-testid="field-email"])::before,
      form[data-testid="form"] [class*="_formFieldContainer"]:has(input#email)::before {
        mask: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Crect x='3' y='5' width='18' height='14' rx='2' fill='none' stroke='black' stroke-width='2'/%3E%3Cpath d='m3.5 7 8.5 6 8.5-6' fill='none' stroke='black' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E") center / contain no-repeat !important;
        -webkit-mask: url("data:image/svg+xml,%3Csvg viewBox='0 0 24 24' xmlns='http://www.w3.org/2000/svg'%3E%3Crect x='3' y='5' width='18' height='14' rx='2' fill='none' stroke='black' stroke-width='2'/%3E%3Cpath d='m3.5 7 8.5 6 8.5-6' fill='none' stroke='black' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E") center / contain no-repeat !important;
      }

      form[data-testid="form"] input {
        box-sizing: border-box !important;
        width: 100% !important;
        min-height: 58px !important;
        padding: 0 18px 0 48px !important;
        border: 1px solid #dfe3e8 !important;
        border-radius: 8px !important;
        background: #fff !important;
        color: ${textColor} !important;
        font-family: ${bodyFont} !important;
        font-size: 1.6rem !important;
        box-shadow: 0 5px 16px rgba(70, 58, 37, 0.07) !important;
        outline-offset: 3px !important;
      }

      form[data-testid="form"] label {
        position: absolute !important;
        left: 48px !important;
        top: 50% !important;
        color: #9a9da4 !important;
        font-family: ${bodyFont} !important;
        font-size: 1.6rem !important;
        line-height: 1 !important;
        transform: translateY(-50%) !important;
        transition: opacity 160ms ease, visibility 160ms ease !important;
        pointer-events: none !important;
      }

      form[data-testid="form"] input:focus + label,
      form[data-testid="form"] input:not(:placeholder-shown) + label {
        opacity: 0 !important;
        visibility: hidden !important;
      }

      form[data-testid="form"] button[type="submit"],
      form[data-testid="form"] button[data-testid="btn-form-submit"] {
        min-height: 35px !important;
        border: 0 !important;
        border-radius: 8px !important;
        background: #56642f !important;
        color: #fff !important;
        font-family: 'Brother 1816 Book', sans-serif !important;
        font-size: 1.6rem !important;
        font-weight: 700 !important;
        line-height: 1 !important;
        cursor: pointer !important;
        display: flex;
        align-content: center;
        justify-content: center;
        align-items: center;
      }

      
      form[data-testid="form"] button[type="submit"]:hover,
      form[data-testid="form"] button[type="submit"]:focus-visible,
      form[data-testid="form"] button[data-testid="btn-form-submit"]:hover,
      form[data-testid="form"] button[data-testid="btn-form-submit"]:focus-visible {
        background: ${oliveDark} !important;
        box-shadow: 0 14px 28px rgba(79, 96, 45, 0.22) !important;
      }
    `;

    const injectStyle = (root) => {
      if (!root || root.getElementById?.(styleId)) return;
      const style = document.createElement('style');
      style.id = styleId;
      style.textContent = formCss;
      root.appendChild(style);
    };

    const styleOpenShadowRoots = (root) => {
      root.querySelectorAll?.('*').forEach((element) => {
        if (!element.shadowRoot) return;
        injectStyle(element.shadowRoot);
        styleOpenShadowRoots(element.shadowRoot);
      });
    };

    const styleEmbed = () => {
      section.querySelectorAll('shopify-forms-embed, #app-embed').forEach((embed) => {
        embed.style.display = 'block';
        embed.style.width = '100%';
        embed.style.maxWidth = '100%';
        embed.style.margin = '0';
        embed.style.padding = '0';

        if (embed.shadowRoot) {
          injectStyle(embed.shadowRoot);
          styleOpenShadowRoots(embed.shadowRoot);
        }
      });
    };

    styleEmbed();

    let attempts = 0;
    const interval = window.setInterval(() => {
      attempts += 1;
      styleEmbed();
      if (attempts > 30) window.clearInterval(interval);
    }, 300);

    new MutationObserver(styleEmbed).observe(section, { childList: true, subtree: true });
  })();
</script>

{% schema %}
{
  "name": "Sign up landing",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "section_label",
      "label": "Accessible section label",
      "default": "Al'Ard signup landing page"
    },
    {
      "type": "checkbox",
      "id": "hide_theme_chrome",
      "label": "Hide theme header and footer",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#efe3d0"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#202020"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Olive accent",
      "default": "#56642f"
    },
    {
      "type": "color",
      "id": "secondary_accent_color",
      "label": "Gold button accent",
