{{ 'section-why-you-should-do-it.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .why-you-should-do-it-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    {% if section.settings.background_image != blank %}
      background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}');
      background-position: {{ section.settings.background_position }};
      background-size: {{ section.settings.background_size }};
      background-repeat: no-repeat;
    {% endif %}
  }
{%- endstyle -%}

<section class="why-you-should-do-it why-you-should-do-it-{{ section.id }}">
  <div class="page-width why-you-should-do-it__container">
    {% if section.settings.heading != blank %}
      <h2 class="why-you-should-do-it__heading inline-richtext h1">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="why-you-should-do-it__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' -%}
          <div class="why-you-should-do-it__block" {{ block.shopify_attributes }}>
            <div class="why-you-should-do-it__icon-container">
              {% if block.settings.svg_icon != blank %}
                <div class="why-you-should-do-it__icon">
                  {{ block.settings.svg_icon }}
                </div>
              {% elsif block.settings.image_icon != blank %}
                {{ block.settings.image_icon | image_url: width: 100 | image_tag: loading: 'lazy', class: 'why-you-should-do-it__icon' }}
              {% endif %}
            </div>
            <div class="why-you-should-do-it__text">
              <h3 class="why-you-should-do-it__block-title h3">{{ block.settings.title }}</h3>
              <p class="why-you-should-do-it__block-desc">{{ block.settings.description }}</p>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {% if section.settings.footer_text != blank %}
      <div class="why-you-should-do-it__footer rte">
        {{ section.settings.footer_text }}
      </div>
    {% endif %}
  </div>

  {% if section.settings.pattern_image != blank %}
    <div class="why-you-should-do-it__pattern">
      {{ section.settings.pattern_image | image_url: width: 300 | image_tag: loading: 'lazy', class: 'why-you-should-do-it__pattern-image' }}
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Why you should do it",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why you should do it"
    },
    {
      "type": "richtext",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "<p>Whether you're restocking your kitchen or sending a meaningful gift, this is your chance to enjoy Palestinian flavors — your way.</p>"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#c9a93a"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "select",
      "id": "background_position",
      "label": "Background Image Position",
      "options": [
        { "value": "top left", "label": "Top Left" },
        { "value": "top center", "label": "Top Center" },
        { "value": "top right", "label": "Top Right" },
        { "value": "center left", "label": "Center Left" },
        { "value": "center center", "label": "Center Center" },
        { "value": "center right", "label": "Center Right" },
        { "value": "bottom left", "label": "Bottom Left" },
        { "value": "bottom center", "label": "Bottom Center" },
        { "value": "bottom right", "label": "Bottom Right" }
      ],
      "default": "center center"
    },
    {
      "type": "select",
      "id": "background_size",
      "label": "Background Image Size",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" }
      ],
      "default": "cover"
    },
    {
      "type": "image_picker",
      "id": "pattern_image",
      "label": "Side Pattern Image"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image_icon",
          "label": "Icon Image"
        },
        {
          "type": "textarea",
          "id": "svg_icon",
          "label": "SVG Icon Code",
          "info": "Paste SVG code here. Overrides Image Icon."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Feature description goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why you should do it",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Customize your box",
            "description": "Based on your taste"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Mix & Match",
            "description": "Pantry staples + specialty items"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Perfect Gift",
            "description": "Create a meaningful present"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Stock Up & Save",
            "description": "Bulk ordering benefits"
          }
        }
      ]
    }
  ]
}
{% endschema %}
