        "custom_liquid": "<div class=\"social-impact-wrapper page-width-desktop\">\n\t<div>\n\t\t<div class=\"collection__title title-wrapper title-wrapper--no-top-margin page-width\">\n\t\t\t<h2 class=\"title inline-richtext h01 scroll-trigger animate--slide-in\">Our Social Impact\n</h2>\n\t\t</div>\n\t\t\n\t\t<p></p><span style=\"font-weight: 400;\">At Al'Ard, our mission is to serve as an anchor firm of support for Palestinian farmers, local producers, and cooperatives, while enhancing the quality of traditional and agricultural products.\n\n\n\n\n\nRecognizing the urgent need to uplift the Palestinian economy, we are driven by our belief in the importance of resilience and the development of Palestinian products to meet global standards.\n\n\t\t\n\t\t<p><a href=\"https://alardproducts.co.uk/products/trees-for-palestine-sponsorship-plant-3-olive-trees\" class=\"button\">PLANT A TREE IN PALESTINE</a></p>\n\t</div>\n\t\n\t<div>\n\t\t<img src=\"https://cdn.shopify.com/s/files/1/0079/4587/9641/files/si.png?v=1736420353\" style=\"max-width: 539px;\">\n\t</div>\n</div>",
