<script>
  function addToCart(variantId, btn) {
    event.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Adding...';

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 }),
    })
      .then((res) => res.json())
      .then((data) => {
        btn.textContent = 'Added!';
        refreshCart();
        setTimeout(() => {
          btn.textContent = 'Order Now';
        }, 500);
      })
      .catch((err) => {
        btn.textContent = 'Error';
        console.error(err);
      })
      .finally(() => (btn.disabled = false));
  }

  function refreshCart() {
    fetch('/?sections=cart-drawer,cart-icon-bubble')
      .then((response) => response.json())
      .then((sections) => {
        // Update the Cart Drawer
        const drawerHTML = sections['cart-drawer'];
        const parser = new DOMParser();
        const drawerDoc = parser.parseFromString(drawerHTML, 'text/html');
        const newDrawer = drawerDoc.querySelector('.drawer');
        const oldDrawer = document.querySelector('.drawer');
        if (newDrawer && oldDrawer) oldDrawer.replaceWith(newDrawer);

        // Update the Cart Icon Bubble
        const bubbleHTML = sections['cart-icon-bubble'];
        const bubbleDoc = parser.parseFromString(bubbleHTML, 'text/html');
        const newBubble = bubbleDoc.querySelector('#cart-icon-bubble');
        const oldBubble = document.querySelector('#cart-icon-bubble');
        if (newBubble && oldBubble) oldBubble.replaceWith(newBubble);
        setTimeout(() => {
          document.querySelector('#cart-icon-bubble').click();
        }, 200);
      })
      .catch((err) => console.error('Cart refresh failed:', err));
  }
</script>

